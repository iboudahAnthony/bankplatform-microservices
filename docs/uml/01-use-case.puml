@startuml Use Case - Plateforme Bancaire Distribuée

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Client" as C
actor "Administrateur" as A
actor "Opérateur Financier" as O
actor "Système OCR/IA" as AI

rectangle "Gestion des Clients" {
  usecase "S'inscrire" as UC1
  usecase "Se connecter" as UC2
  usecase "Soumettre documents KYC" as UC3
  usecase "Consulter profil" as UC4
  usecase "Modifier profil" as UC5
}

rectangle "Gestion des Comptes" {
  usecase "Ouvrir un compte" as UC6
  usecase "Consulter solde" as UC7
  usecase "Consulter historique" as UC8
  usecase "Clôturer un compte" as UC9
}

rectangle "Transactions" {
  usecase "Effectuer un dépôt" as UC10
  usecase "Effectuer un retrait" as UC11
  usecase "Transfert intra-opérateur" as UC12
  usecase "Transfert inter-opérateur" as UC13
}

rectangle "Gestion des Prêts" {
  usecase "Demander un prêt" as UC14
  usecase "Consulter statut prêt" as UC15
  usecase "Consulter échéancier" as UC16
  usecase "Rembourser un prêt" as UC17
}

rectangle "Notifications" {
  usecase "Recevoir notifications" as UC18
  usecase "Consulter notifications" as UC19
}

rectangle "Administration" {
  usecase "Gérer les opérateurs" as UC20
  usecase "Gérer les utilisateurs" as UC21
  usecase "Consulter rapports" as UC22
  usecase "Consulter audits" as UC23
  usecase "Configurer règles métier" as UC24
}

rectangle "Gestion des Prêts - Opérateur" {
  usecase "Analyser dossier prêt" as UC25
  usecase "Valider / Rejeter prêt" as UC26
  usecase "Générer échéancier" as UC27
}

rectangle "OCR / IA" {
  usecase "Extraire infos documents" as UC28
  usecase "Vérifier authenticité" as UC29
  usecase "Alimenter dossier client" as UC30
}

' Client
C --> UC1
C --> UC2
C --> UC3
C --> UC4
C --> UC5
C --> UC6
C --> UC7
C --> UC8
C --> UC9
C --> UC10
C --> UC11
C --> UC12
C --> UC13
C --> UC14
C --> UC15
C --> UC16
C --> UC17
C --> UC18
C --> UC19

' Administrateur
A --> UC2
A --> UC20
A --> UC21
A --> UC22
A --> UC23
A --> UC24

' Opérateur
O --> UC2
O --> UC25
O --> UC26
O --> UC27
O --> UC22
O --> UC24

' IA / OCR
UC3 ..> UC28 : <<include>>
UC14 ..> UC28 : <<include>>
UC28 ..> UC29 : <<include>>
UC28 ..> UC30 : <<include>>
AI --> UC28

@enduml
