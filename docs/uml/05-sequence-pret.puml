@startuml Séquence - Demande et Traitement de Prêt

skinparam sequenceArrowThickness 2
skinparam roundcorner 10

title Diagramme de Séquence : Demande de Prêt

actor "Client" as C
actor "Analyste\nOpérateur" as ANALYST
participant "React\nFrontend" as UI
participant "API Gateway" as GW
participant "loan-service\n(Python)" as LOAN
participant "customer-service" as CUSTOMER
participant "document-service\n(OCR)" as DOC
participant "account-service" as ACC
participant "notification-service" as NOTIF
participant "Kafka" as KAFKA
database "loan-db" as LOAN_DB

== Soumission Demande ==

C -> UI : Remplit formulaire prêt\n(montant, durée, objet)
C -> UI : Upload bulletins salaire + relevés bancaires
UI -> GW : POST /api/loans/apply\n{clientId, montant, durée, documents[]}
GW -> LOAN : POST /loans/apply

LOAN -> CUSTOMER : GET /customers/{clientId}
CUSTOMER --> LOAN : {nom, statut: VERIFIED, score: 720}

LOAN -> DOC : POST /documents/process\n{bulletins_salaire, relevés}
DOC -> DOC : OCR extraction
note over DOC
  Extraction automatique :
  - Salaire net mensuel
  - Employeur
  - Ancienneté
  - Solde moyen compte
end note
DOC --> LOAN : {salaire: 150000, ancienneté: 3ans,\nsolde_moyen: 200000}

LOAN -> LOAN : Calcul scoring automatique
note over LOAN
  Score = f(salaire, ancienneté,
  historique_remboursement,
  ratio_endettement)
end note

LOAN -> LOAN_DB : INSERT loan\n{statut: SUBMITTED}
LOAN -> KAFKA : Publish LoanRequested\n{loanId, clientId, score}

LOAN --> GW : 201 Created\n{loanId, statut: UNDER_REVIEW}
GW --> UI : 201 Created
UI --> C : "Demande soumise, en cours d'analyse"

== Analyse par l'Opérateur ==

KAFKA -> NOTIF : Consume LoanRequested
NOTIF -> ANALYST : Email "Nouveau dossier prêt à analyser"

ANALYST -> UI : Consulte dossier prêt
UI -> GW : GET /api/loans/{loanId}
GW -> LOAN : GET /loans/{loanId}
LOAN --> GW : Dossier complet + score IA
GW --> UI : Dossier complet
UI --> ANALYST : Affiche dossier + recommandation IA

alt Prêt Approuvé

  ANALYST -> UI : Approuve le prêt
  UI -> GW : PUT /api/loans/{loanId}/approve\n{taux: 8%, conditions}
  GW -> LOAN : PUT /loans/{loanId}/approve

  LOAN -> LOAN : Générer échéancier de remboursement
  note over LOAN
    Calcul mensualités :
    M = P * [r(1+r)^n] / [(1+r)^n - 1]
    P=capital, r=taux mensuel, n=durée
  end note

  LOAN -> LOAN_DB : UPDATE statut: APPROVED\nINSERT échéances[]
  LOAN -> KAFKA : Publish LoanApproved\n{loanId, montant, échéancier}

  KAFKA -> NOTIF : Consume LoanApproved
  NOTIF -> C : Email + SMS "Prêt approuvé !\nMontant: XXXXX XOF"

  KAFKA -> ACC : Consume LoanApproved
  ACC -> ACC : Créditer compte client\n(montant prêt)

else Prêt Rejeté

  ANALYST -> UI : Rejette le prêt + motif
  UI -> GW : PUT /api/loans/{loanId}/reject\n{motif}
  GW -> LOAN : PUT /loans/{loanId}/reject
  LOAN -> LOAN_DB : UPDATE statut: REJECTED
  LOAN -> KAFKA : Publish LoanRejected\n{loanId, motif}
  KAFKA -> NOTIF : Consume LoanRejected
  NOTIF -> C : Email "Demande rejetée : {motif}"

end

== Remboursement ==

C -> UI : Effectue remboursement mensualité
UI -> GW : POST /api/loans/{loanId}/repay\n{montant, échéanceId}
GW -> LOAN : POST /loans/{loanId}/repay
LOAN -> ACC : Débiter compte client
ACC --> LOAN : Débit OK
LOAN -> LOAN_DB : UPDATE échéance: PAID
LOAN -> KAFKA : Publish LoanRepaymentMade
KAFKA -> NOTIF : Consume LoanRepaymentMade
NOTIF -> C : "Remboursement enregistré\nProchaine échéance: DD/MM/YYYY"

@enduml
