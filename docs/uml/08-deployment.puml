@startuml Diagramme de Déploiement - Kubernetes

skinparam nodeStyle rectangle
skinparam backgroundColor #FAFAFA

title Diagramme de Déploiement - Cluster Kubernetes

node "Kubernetes Cluster" #EBF5FB {

  node "Namespace: ingress" #E8F8E8 {
    component "Nginx Ingress Controller" as INGRESS
    component "Cert-Manager (TLS)" as CERT
  }

  node "Namespace: infrastructure" #FEF9E7 {
    component "Eureka Server\n(2 replicas)" as EUREKA
    component "Config Server\n(2 replicas)" as CONFIG
    component "API Gateway\n(3 replicas)" as GW
    component "Kafka Cluster\n(3 brokers)" as KAFKA
    component "Zookeeper\n(3 replicas)" as ZK
  }

  node "Namespace: services-java" #C8E6C9 {
    component "auth-service\n(2 replicas)" as AUTH
    component "customer-service\n(2 replicas)" as CUSTOMER
    component "account-service\n(3 replicas)" as ACCOUNT
    component "transaction-service\n(3 replicas)" as TX
    component "operator-service\n(2 replicas)" as OPERATOR
  }

  node "Namespace: services-python" #FDF2F8 {
    component "loan-service\n(2 replicas)" as LOAN
    component "document-service\n(2 replicas)" as DOC
    component "reporting-service\n(1 replica)" as REPORT
  }

  node "Namespace: services-node" #FFF9C4 {
    component "notification-service\n(2 replicas)" as NOTIF
    component "audit-service\n(2 replicas)" as AUDIT
  }

  node "Namespace: databases" #FFCCBC {
    database "PostgreSQL\nauth-db" as AUTH_DB
    database "PostgreSQL\ncustomer-db" as CUST_DB
    database "PostgreSQL\naccount-db" as ACC_DB
    database "PostgreSQL\ntransaction-db" as TX_DB
    database "PostgreSQL\nloan-db" as LOAN_DB
    database "MongoDB\naudit-db" as MONGO
    database "MinIO\n(Object Storage)" as MINIO
    database "Redis\n(Cache)" as REDIS
  }

  node "Namespace: monitoring" #F4ECF7 {
    component "Prometheus" as PROM
    component "Grafana" as GRAFANA
    component "Zipkin" as ZIPKIN
    component "Elasticsearch" as ES
    component "Kibana" as KIBANA
    component "Logstash" as LOGSTASH
  }
}

cloud "Internet" {
  actor "Utilisateurs" as USERS
  actor "CI/CD Pipeline\n(GitHub Actions)" as CICD
}

node "Container Registry\n(Docker Hub / ECR)" as REGISTRY

' Connexions
USERS --> INGRESS : HTTPS
INGRESS --> GW
CICD --> REGISTRY : Push images
REGISTRY --> EUREKA : Pull & Deploy
REGISTRY --> GW : Pull & Deploy
REGISTRY --> AUTH : Pull & Deploy

GW --> AUTH
GW --> CUSTOMER
GW --> ACCOUNT
GW --> TX
GW --> LOAN
GW --> DOC
GW --> REPORT
GW --> NOTIF
GW --> OPERATOR

AUTH --> AUTH_DB
CUSTOMER --> CUST_DB
ACCOUNT --> ACC_DB
TX --> TX_DB
LOAN --> LOAN_DB
AUDIT --> MONGO
DOC --> MINIO
GW --> REDIS : Cache JWT

KAFKA --> ZK

AUTH ..> PROM : Metrics
CUSTOMER ..> PROM : Metrics
TX ..> PROM : Metrics
PROM --> GRAFANA

AUTH ..> ZIPKIN : Traces
TX ..> ZIPKIN : Traces

AUTH ..> LOGSTASH : Logs
TX ..> LOGSTASH : Logs
LOGSTASH --> ES
ES --> KIBANA

@enduml
